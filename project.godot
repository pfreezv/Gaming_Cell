; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but the file format allows this.

config_version=5

[application]

config/name="PRIMORDIAL"
config/description="El primer juego de estrategia sobre el origen molecular de la vida."
run/main_scene="res://src/scenes/Main.tscn"
config/features=PackedStringArray("4.3", "GL Compatibility")

[autoload]

GameState="*res://src/core/GameState.gd"
MoleculeSystem="*res://src/core/MoleculeSystem.gd"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
