      "NH3":      8,
      "CO2":      8,
      "H2S":      8,
      "CH4":      5,
      "FORMAMID": 8,
      "FE2":      5,
      "PO4":      5
    },
    "temp_boost_divisor": 100,
    "surface_zone_ratio": 0.60
  },

  "reactions": {
    "_note": "Prebiotic reaction table. chance = probability per collision check per tick. Ref: Miller 1953, Oró 1961, Ferris 2002.",
    "_science": "All reactions are scientifically documented. Parameters are simplified for gameplay while preserving relative rates.",
    "collision_extra_radius": 18,
    "max_reactions_per_tick": 3,
    "temp_boost_divisor": 120,
    "uv_boost": 0.8,
    "ph_boost_threshold_high": 6.0,
    "ph_boost_high": 1.2,
    "ph_boost_threshold_mid": 5.0,
    "ph_boost_mid": 0.9,
    "ph_boost_low": 0.6,
    "table": {
      "CH4_NH3_to_HCN":        { "reactants":["CH4","NH3"],       "product":"HCN",       "chance":0.015, "min_temp":40, "uv_only":true,  "ref":"Miller & Urey 1953" },
      "HCN_HCN_to_FORMAMID":   { "reactants":["HCN","HCN"],       "product":"FORMAMID",  "chance":0.012, "min_temp":40, "uv_only":false, "ref":"Oró 1961 - purine precursor" },
      "HCN_H2O_to_AMINO":      { "reactants":["HCN","H2O"],       "product":"AMINO",     "chance":0.012, "min_temp":30, "uv_only":false, "ref":"Strecker synthesis" },
      "HCN_H2O_to_BASE":       { "reactants":["HCN","H2O"],       "product":"BASE",      "chance":0.010, "min_temp":25, "uv_only":false, "ref":"Pyrimidine synthesis" },
      "NH3_H2O_to_AMINO":      { "reactants":["NH3","H2O"],       "product":"AMINO",     "chance":0.008, "min_temp":35, "uv_only":false, "ref":"Miller 1953" },
      "CO2_H2S_to_LIPID":      { "reactants":["CO2","H2S"],       "product":"LIPID",     "chance":0.009, "min_temp":20, "uv_only":false, "ref":"Hydrothermal vent chemistry" },
      "FORMAMID_H2O_to_BASE_A":{ "reactants":["FORMAMID","H2O"],  "product":"BASE_A",    "chance":0.010, "min_temp":35, "uv_only":false, "ref":"Adenine synthesis pathway" },
      "FORMAMID_HCN_to_BASE_G":{ "reactants":["FORMAMID","HCN"],  "product":"BASE_G",    "chance":0.009, "min_temp":40, "uv_only":false, "ref":"Guanine synthesis" },
      "AMINO_AMINO_to_PEPTID":  { "reactants":["AMINO","AMINO"],   "product":"PEPTID",    "chance":0.009, "min_temp":45, "uv_only":false, "ref":"Peptide bond formation" },
      "AMINO_PO4_to_RIBOSA":   { "reactants":["AMINO","PO4"],     "product":"RIBOSA",    "chance":0.009, "min_temp":35, "uv_only":false, "ref":"Formose reaction variant" },
      "BASE_RIBOSA_to_NUCLEOSID":{ "reactants":["BASE","RIBOSA"],  "product":"NUCLEOSID", "chance":0.010, "min_temp":40, "uv_only":false, "ref":"N-glycosidic bond formation" },
      "NUCLEOSID_PO4_to_NMP":  { "reactants":["NUCLEOSID","PO4"], "product":"NMP",       "chance":0.010, "min_temp":35, "uv_only":false, "ref":"Ferris 2002 - clay catalysis" },
      "NMP_NMP_to_RNA":        { "reactants":["NMP","NMP"],       "product":"RNA",       "chance":0.008, "min_temp":50, "uv_only":false, "ref":"Phosphodiester bond formation" },
      "NMP_PO4_to_ATP":        { "reactants":["NMP","PO4"],       "product":"ATP",       "chance":0.008, "min_temp":45, "uv_only":false, "ref":"ATP synthesis - energy storage" },
      "AMINO_FE2_catalysis":   { "reactants":["AMINO","FE2"],     "product":"AMINO",     "chance":0.005, "min_temp":30, "uv_only":false, "ref":"Iron catalysis of amino acid reactions" }
    }
  },

