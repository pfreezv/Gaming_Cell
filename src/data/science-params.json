    "GLU": { "code":"Glu", "color":"#fb7185", "charge":-1, "hydrophobicity":0.10, "flexibility":0.45,"special":"metal",    "mass":147, "abundance_weight":8,  "origin":"Miller-Urey" },
    "VAL": { "code":"Val", "color":"#4ade80", "charge":0,  "hydrophobicity":0.76, "flexibility":0.4, "special":"hydcore",  "mass":117, "abundance_weight":7,  "origin":"Miller-Urey" },
    "SER": { "code":"Ser", "color":"#60a5fa", "charge":0,  "hydrophobicity":0.05, "flexibility":0.75,"special":"phospho",  "mass":105, "abundance_weight":5,  "origin":"Murchison" },
