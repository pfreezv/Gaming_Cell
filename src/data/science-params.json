  "physics": {
    "_note": "Movement parameters. Maxwell-Boltzmann: speed ∝ sqrt(reference_mass / molecule_mass). CO2 (44) as reference.",
    "reference_mass_for_mb": 44,
    "base_speed_divisor": 55,
    "min_speed": 0.4,
    "gas_vx_range":   [-1.4, 1.4],
    "gas_vy_range":   [-1.4, 1.4],
    "liquid_vx_range":[-1.0, 1.0],
    "liquid_vy_range":[-1.0, 1.0],
    "solid_gravity_increment": 0.05,
    "solid_max_vy": 1.2,
    "solid_x_damping": 0.2,
    "liquid_brownian_delta": 0.06,
    "gas_brownian_delta": 0.08,
    "ocean_wall_bounce_boost": 0.1
  },

  "dissolution": {
    "_note": "Rates at which gases dissolve into ocean. Ref: Henry's Law approximations.",
    "_science": "Higher rate = more soluble. HCN is very soluble (polar, reactive). CH4 barely dissolves (nonpolar).",
    "gas_rates": {
      "HCN":      0.014,
      "CO2":      0.009,
      "H2S":      0.009,
      "NH3":      0.007,
      "FORMAMID": 0.010,
      "CH4":      0.003
    },
    "solid_rates": {
      "FE2": 0.001,
      "PO4": 0.001
    },
    "liquid_caps": {
      "_note": "Max dissolved copies of each type in ocean simultaneously",
