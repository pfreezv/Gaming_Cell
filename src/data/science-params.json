  "nucleotide_bases": {
    "_note": "5 nitrogenous bases. Ref: Oró 1961, Sutherland 2009",
    "A": { "letter":"A", "color":"#c084fc", "type":"purine",     "pair_rna":"U", "pair_dna":"T", "h_bonds":2, "can_form_atp":true,  "stability":0.72, "reactivity":0.88, "synthesis":"5x HCN (Oró reaction)" },
    "G": { "letter":"G", "color":"#818cf8", "type":"purine",     "pair_rna":"C", "pair_dna":"C", "h_bonds":3, "thermostable":true,  "stability":0.85, "reactivity":0.75, "synthesis":"HCN + formamidine" },
    "C": { "letter":"C", "color":"#67e8f9", "type":"pyrimidine", "pair_rna":"G", "pair_dna":"G", "h_bonds":3, "deaminates_to":"U",  "stability":0.60, "reactivity":0.78, "synthesis":"cyanoacetylene + urea" },
    "U": { "letter":"U", "color":"#34d399", "type":"pyrimidine", "pair_rna":"A", "pair_dna":null,"h_bonds":2, "only_rna":true,      "stability":0.68, "reactivity":0.70, "synthesis":"urea + maleic acid" },
    "T": { "letter":"T", "color":"#fbbf24", "type":"pyrimidine", "pair_rna":null,"pair_dna":"A", "h_bonds":2, "only_dna":true,      "stability":0.90, "reactivity":0.60, "synthesis":"methylation of U (late, requires SAM)" }
